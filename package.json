{
  "name": "tanstack-viteplus",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vp dev --port 3000",
    "dev:docker": "vp dev --host 0.0.0.0 --port 3000",
    "build": "vp build",
    "preview": "vp preview",
    "storybook": "storybook dev -p 6006",
    "storybook:docker": "storybook dev -p 6006 --host 0.0.0.0",
    "build-storybook": "storybook build",
    "start": "node .output/server/index.mjs",
    "db:push": "vp exec drizzle-kit push",
    "db:generate": "vp exec drizzle-kit generate",
    "db:migrate": "vp exec drizzle-kit migrate",
    "db:seed": "vp exec tsx src/lib/server/seed.ts",
    "docker:dev": "docker compose --profile dev up --build",
    "docker:prod": "docker compose --profile prod up --build",
    "docker:storybook": "docker compose --profile storybook up --build",
    "test": "vp test run",
    "prepare": "vp config"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "nitro": "npm:nitro-nightly@latest",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.0.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.2.18",
    "@storybook/react-vite": "^10.2.18",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260317.1",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "storybook": "^10.2.18",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "vite": "*"
      }
    }
  },
  "packageManager": "pnpm@10.32.1"
}
